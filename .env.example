# Required
# If PostgreSQL runs on the host (not in Docker), use host.docker.internal instead of localhost
DATABASE_URL=postgresql://user:password@host.docker.internal:5432/session_ai_mcp
MCP_EXTERNAL_URL=https://mcp.yourdomain.com

# Optional
MCP_HOST=0.0.0.0
MCP_PORT=8765
TOKEN_TTL_DAYS=30
APP_NAME=session-ai-mcp
MCP_ALLOWED_ORIGINS=
