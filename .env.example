# Required
# DATABASE_URL uses the Docker service name 'db' as host — do not change to localhost
DATABASE_URL=postgresql://mcp:changeme@db:5432/session_ai_mcp
MCP_EXTERNAL_URL=https://mcp.yourdomain.com

# Optional
MCP_HOST=0.0.0.0
MCP_PORT=8765
TOKEN_TTL_DAYS=30
APP_NAME=session-ai-mcp
MCP_ALLOWED_ORIGINS=

# PostgreSQL (used by the db service in docker-compose)
POSTGRES_DB=session_ai_mcp
POSTGRES_USER=mcp
POSTGRES_PASSWORD=changeme
